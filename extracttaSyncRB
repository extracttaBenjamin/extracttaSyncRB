#!/usr/bin/env bash
# ExtracttaSyncRB - Engine de Orquestração

CONF="/opt/extracttaSyncRB/config.env"
SER_SCRIPT="/opt/extracttaSyncRB/extracttaSync-SER.sh"
RB_LOG="/opt/extracttaSync/logs/ExtracttaSyncReport.log"
[[ -f "$CONF" ]] && source "$CONF"

log_rb() { echo "$(date '+%Y-%m-%d %H:%M:%S') - [RB] $1" >> "$RB_LOG"; }

# Parse de Argumentos
while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--from) FROM="$2"; shift 2 ;;
        -o|--outputMode) MODE="$2"; shift 2 ;;
        *) echo "Uso: extracttaSyncRB -f <all|localhost|alias> -o <S|F|M|A>"; exit 1 ;;
    esac
done

execute_task() {
    local target=$1
    log_rb "Iniciando captura em: $target"
    if [[ "$target" == "localhost" ]]; then
        bash "$SER_SCRIPT" "$MONGO_URI" "$MODE" [cite: 36]
    else
        # Envia o script de coleta via SSH para execução em memória no host remoto
        ssh -q "$target" "bash -s" -- "$MONGO_URI" "$MODE" < "$SER_SCRIPT"
    fi
}

case "$FROM" in
    "all")
        execute_task "localhost"
        for h in $(grep -i "^Host ExtracttaSync" "$HOME/.ssh/config" | awk '{print $2}'); do
            execute_task "$h" [cite: 21]
        done
        ;;
    *) execute_task "$FROM" ;;
esac